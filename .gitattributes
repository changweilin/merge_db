# Normalize line endings to LF in the repo and working tree
* text=auto eol=lf

# Source code
*.kt         text eol=lf
*.kts        text eol=lf
*.java       text eol=lf

# Android / Gradle
*.xml        text eol=lf
*.gradle     text eol=lf
*.pro        text eol=lf
*.properties text eol=lf
*.json       text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.md         text eol=lf

# Shell
*.sh         text eol=lf

# Binary — never touch line endings
*.db         binary
*.apk        binary
*.aar        binary
*.jar        binary
*.keystore   binary
*.jks        binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.webp       binary
*.gif        binary
*.ico        binary
*.bin        binary
*.lock       binary
